---
import SiteShell from '../components/SiteShell.astro';
import { series, site } from '../data/site';
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path = '') => `${BASE}/${path}`.replace(/\/+$|(?<!:)\/\//g, '/');
---
<SiteShell lang="en" title="Citrus Gallery" description={site.description.en}>
  <section class="hero container">
    <span class="eyebrow">Citrus Gallery</span>
    <h1>Staring at mountains<br />and the stars.</h1>
    <p>
      Citrus Gallery is where I share photographs I love — quiet mountains, night skies, water at dusk,
      and small human moments that stay with me.
    </p>
    <div class="hero-actions">
      <a class="button primary" href={withBase('gallery/')}>Enter gallery</a>
      <a class="button" href={withBase('zh/')}>切换中文</a>
    </div>
  </section>

  <section class="section container">
    <div class="series-grid">
      {series.map((item) => (
        <a class="series-card image-card" href={withBase(`gallery/#${item.slug}`)} style={`background-image:url(${withBase(item.cover.replace(/^\//, ''))})`}>
          <div class="series-card-content">
            <h3>{item.title.en}</h3>
            <p>{item.summary.en}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="section container">
    <div class="section-heading">
      <div>
        <span class="eyebrow">About</span>
      </div>
    </div>
    <div class="about-panel">
      Made by Yuzu and her bot Jolyne.
    </div>
  </section>
</SiteShell>
