---
import SiteShell from '../../components/SiteShell.astro';
import { series } from '../../data/site';
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path = '') => `${BASE}/${path}`.replace(/\/+$|(?<!:)\/\//g, '/');
---
<SiteShell lang="zh" title="作品 · Citrus Gallery" description="Citrus Gallery 作品总览">
  <section class="hero container">
    <span class="eyebrow">Gallery</span>
    <h1>望着群山，<br />也望着星空。</h1>

  </section>
  <section class="section container gallery-list">
    {series.map((item) => (
      <section class="series-detail" id={item.slug}>
        <div class="section-heading">
          <div>
            <h2>{item.title.zh}</h2>
          </div>
          <p>{item.summary.zh}</p>
        </div>
        <div class="photo-grid">
          {item.images.map((image, index) => (
            <figure class={`photo-figure ${index === 0 ? 'photo-figure-featured' : ''}`}>
              <button
                class={`photo-card photo-trigger ${index === 0 ? 'photo-card-featured' : ''}`}
                type="button"
                data-image={withBase(image.src.replace(/^\//, ''))}
                data-caption={image.caption.zh}
                data-alt={`${item.title.zh} ${index + 1}`}
                data-type={image.type || 'image'}
                data-poster={image.poster ? withBase(image.poster.replace(/^\//, '')) : ''}
              >
                {image.type === 'video' ? (
                  <video src={withBase(image.src.replace(/^\//, ''))} poster={image.poster ? withBase(image.poster.replace(/^\//, '')) : ''} muted playsinline preload="metadata" />
                ) : (
                  <img src={withBase(image.src.replace(/^\//, ''))} alt={`${item.title.zh} ${index + 1}`} loading="lazy" />
                )}
              </button>
            </figure>
          ))}
        </div>
      </section>
    ))}
  </section>

  <dialog class="lightbox" id="lightbox-zh">
    <form method="dialog" class="lightbox-backdrop">
      <button class="lightbox-close" aria-label="关闭">×</button>
    </form>
    <div class="lightbox-panel">
      <img id="lightbox-image-zh" src="" alt="" />
      <video id="lightbox-video-zh" controls playsinline style="display:none"></video>
      <p id="lightbox-caption-zh" class="lightbox-caption"></p>
    </div>
  </dialog>

  <script>
    const lightbox = document.getElementById('lightbox-zh');
    const image = document.getElementById('lightbox-image-zh');
    const video = document.getElementById('lightbox-video-zh');
    const caption = document.getElementById('lightbox-caption-zh');
    const triggers = document.querySelectorAll('.photo-trigger');

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const src = trigger.getAttribute('data-image') || '';
        const alt = trigger.getAttribute('data-alt') || '';
        const text = trigger.getAttribute('data-caption') || '';
        const type = trigger.getAttribute('data-type') || 'image';
        const poster = trigger.getAttribute('data-poster') || '';

        if (type === 'video') {
          image.style.display = 'none';
          video.style.display = 'block';
          video.setAttribute('src', src);
          if (poster) video.setAttribute('poster', poster);
        } else {
          video.pause();
          video.removeAttribute('src');
          video.style.display = 'none';
          image.style.display = 'block';
          image.setAttribute('src', src);
          image.setAttribute('alt', alt);
        }

        caption.textContent = text;
        caption.style.display = text ? 'block' : 'none';
        lightbox.showModal();
      });
    });

    lightbox?.addEventListener('click', (event) => {
      const panel = lightbox.querySelector('.lightbox-panel');
      if (panel && !panel.contains(event.target)) {
        video.pause();
        lightbox.close();
      }
    });

    lightbox?.addEventListener('close', () => {
      video.pause();
    });
  </script>
</SiteShell>
