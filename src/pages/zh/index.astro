---
import SiteShell from '../../components/SiteShell.astro';
import { series, site } from '../../data/site';
---
<SiteShell lang="zh" title="Citrus Gallery" description={site.description.zh}>
  <section class="hero container">
    <span class="eyebrow">Citrus Gallery</span>
    <h1>望着群山，<br />也望着星空。</h1>
    <p>
      Citrus Gallery 是我分享喜欢的照片的地方——这里有安静的山、夜里的星、水边的暮色，
      还有那些让我想停下来多看一会儿的人间瞬间。
    </p>
    <div class="hero-actions">
      <a class="button primary" href="/zh/gallery">进入作品</a>
      <a class="button" href="/">Switch to English</a>
    </div>
  </section>

  <section class="section container">
    <div class="series-grid">
      {series.map((item) => (
        <a class="series-card image-card" href={`/zh/gallery#${item.slug}`} style={`background-image:url(${item.cover})`}>
          <div class="series-card-content">
            <h3>{item.title.zh}</h3>
            <p>{item.summary.zh}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="section container">
    <div class="section-heading">
      <div>
        <span class="eyebrow">关于</span>
      </div>
    </div>
    <div class="about-panel">
      这是 Yuzu 和她的 bot Jolyne 一起做的。
    </div>
  </section>
</SiteShell>
