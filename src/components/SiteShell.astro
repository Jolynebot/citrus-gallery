---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';

interface Props {
  lang: 'en' | 'zh';
  title: string;
  description: string;
}
const { lang, title, description } = Astro.props;
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path = '') => `${BASE}/${path}`.replace(/\/+$|(?<!:)\/\//g, '/');
const nav = site.nav[lang].map((item) => ({ ...item, href: withBase(item.href) }));
---
<Layout title={title} description={description} lang={lang}>
  <header class="site-header">
    <div class="container site-header-inner">
      <a class="brand" href={lang === 'zh' ? withBase('zh/') : withBase('')}>
        <span class="brand-title">Citrus Gallery</span>
      </a>
      <nav class="nav">
        {nav.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer class="footer">
    <div class="container">
      Citrus Gallery · Yuzu · Jolyne
    </div>
  </footer>
</Layout>
