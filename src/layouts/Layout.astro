---
interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'zh';
}
const { title, description = 'Citrus Gallery', lang = 'en' } = Astro.props;
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path = '') => `${BASE}/${path}`.replace(/\/+$|(?<!:)\/\//g, '/');
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
    <link rel="icon" href={withBase('favicon.ico')} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg: #0b0d10;
    --bg-soft: #12161b;
    --panel: #161b22;
    --line: rgba(255,255,255,.08);
    --text: #f5f1e8;
    --muted: #b9b0a2;
    --accent: #f0b35b;
    --accent-soft: rgba(240,179,91,.14);
    --max: 1160px;
  }

  * { box-sizing: border-box; }
  html, body {
    margin: 0;
    min-height: 100%;
    background:
      radial-gradient(circle at top, rgba(240,179,91,.08), transparent 30%),
      linear-gradient(180deg, #090b0e 0%, #0b0d10 100%);
    color: var(--text);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; display: block; }

  .container {
    width: min(var(--max), calc(100% - 32px));
    margin: 0 auto;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(14px);
    background: rgba(11,13,16,.65);
    border-bottom: 1px solid var(--line);
  }

  .site-header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    min-height: 68px;
    gap: 18px;
  }

  .brand {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .brand-title { font-size: 1rem; letter-spacing: .08em; text-transform: uppercase; }
  .brand-subtitle { color: var(--muted); font-size: .82rem; }

  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    font-size: .95rem;
    color: var(--muted);
  }
  .nav a:hover { color: var(--text); }

  .hero {
    padding: 88px 0 56px;
    display: grid;
    gap: 28px;
  }

  .eyebrow {
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: .18em;
    font-size: .76rem;
  }

  h1, h2, h3, p { margin: 0; }
  .hero h1 {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(2.8rem, 8vw, 5.6rem);
    line-height: .95;
    max-width: 16ch;
    font-weight: 500;
  }
  .hero p {
    color: var(--muted);
    max-width: 60ch;
    line-height: 1.75;
    font-size: 1.02rem;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 18px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: var(--panel);
    transition: .2s ease;
  }
  .button.primary {
    background: var(--accent);
    color: #17120b;
    border-color: transparent;
    font-weight: 600;
  }
  .button:hover { transform: translateY(-1px); }

  .section {
    padding: 18px 0 56px;
  }

  .section-heading {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: end;
    margin-bottom: 20px;
  }

  .section-heading h2 {
    font-size: 1.5rem;
    font-weight: 600;
  }

  .section-heading p {
    color: var(--muted);
    max-width: 56ch;
    line-height: 1.65;
  }

  .series-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 16px;
  }

  .series-card {
    grid-column: span 4;
    background: linear-gradient(180deg, rgba(255,255,255,.02), rgba(255,255,255,.01));
    border: 1px solid var(--line);
    border-radius: 20px;
    overflow: hidden;
    min-height: 320px;
    display: flex;
    flex-direction: column;
    justify-content: end;
    position: relative;
    isolation: isolate;
  }

  .series-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 0%, rgba(8,9,12,.82) 85%);
    z-index: -1;
  }

  .series-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top, rgba(240,179,91,.18), transparent 36%);
    z-index: -2;
  }

  .series-card.image-card {
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
  }

  .series-card-content {
    padding: 22px;
    display: grid;
    gap: 10px;
  }

  .series-card h3 { font-size: 1.2rem; }
  .series-card p { color: var(--muted); line-height: 1.65; font-size: .95rem; }

  .gallery-list {
    display: grid;
    gap: 48px;
  }

  .series-detail {
    display: grid;
    gap: 20px;
  }

  .series-intro {
    max-width: 52ch;
    color: var(--muted);
    line-height: 1.8;
    font-size: 1rem;
    margin-top: -4px;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 14px;
  }

  .photo-figure {
    grid-column: span 4;
    margin: 0;
    display: grid;
    gap: 10px;
  }

  .photo-figure-featured {
    grid-column: span 6;
  }

  .photo-card {
    grid-column: span 4;
    display: block;
    width: 100%;
    padding: 0;
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--bg-soft);
    min-height: 220px;
  }

  .photo-trigger {
    cursor: zoom-in;
    appearance: none;
    text-align: inherit;
  }

  .photo-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .photo-card-featured {
    min-height: 340px;
  }

  .photo-caption {
    color: var(--muted);
    font-size: .95rem;
    line-height: 1.75;
    padding: 0 4px;
  }

  .lightbox {
    width: min(1100px, calc(100% - 24px));
    border: 1px solid var(--line);
    background: rgba(10, 12, 15, .96);
    color: var(--text);
    border-radius: 24px;
    padding: 0;
  }

  .lightbox::backdrop {
    background: rgba(0,0,0,.78);
    backdrop-filter: blur(6px);
  }

  .lightbox-panel {
    padding: 20px;
    display: grid;
    gap: 14px;
  }

  .lightbox-panel img {
    width: 100%;
    max-height: 78vh;
    object-fit: contain;
    border-radius: 16px;
    background: #0a0c0f;
  }

  .lightbox-caption {
    color: var(--muted);
    line-height: 1.8;
    font-size: 1rem;
    margin: 0;
    padding: 0 4px 2px;
  }

  .lightbox-backdrop {
    position: absolute;
    top: 16px;
    right: 16px;
    margin: 0;
  }

  .lightbox-close {
    width: 40px;
    height: 40px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255,255,255,.06);
    color: var(--text);
    font-size: 1.4rem;
    cursor: pointer;
  }

  .about-panel {
    background: var(--bg-soft);
    border: 1px solid var(--line);
    border-radius: 24px;
    padding: 24px;
    line-height: 1.8;
    color: var(--muted);
  }

  .footer {
    border-top: 1px solid var(--line);
    color: var(--muted);
    padding: 24px 0 40px;
    font-size: .92rem;
  }

  @media (max-width: 900px) {
    .series-card { grid-column: span 6; }
    .photo-figure { grid-column: span 6; }
    .photo-figure-featured { grid-column: span 12; }
  }
  @media (max-width: 640px) {
    .site-header-inner,
    .section-heading { align-items: start; flex-direction: column; }
    .series-card,
    .photo-figure,
    .photo-figure-featured,
    .photo-card,
    .photo-card-featured { grid-column: 1 / -1; min-height: 260px; }
    .hero { padding-top: 64px; }
  }
</style>
